{
  "name": "lumitask",
  "version": "0.1.1",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev -p 3179",
    "build": "next build",
    "start": "next start -p 3179",
    "lint": "eslint",
    "cli:dev": "tsx cli/index.ts",
    "electron:compile": "npx esbuild electron/main.ts electron/preload.ts electron/server.ts --bundle --platform=node --external:electron --external:electron-updater --outdir=electron/dist --format=cjs",
    "electron:rebuild-native": "npx @electron/rebuild -f -w better-sqlite3 && bash -c 'SRC=$(find node_modules -name better_sqlite3.node | head -1) && DST=$(find .next/standalone -name better_sqlite3.node | head -1) && [ -n \"$DST\" ] && cp \"$SRC\" \"$DST\" && echo native module copied'",
    "electron:prepare-standalone": "node electron/scripts/prepare-standalone.js",
    "electron:dev": "pnpm build && pnpm electron:prepare-standalone && pnpm electron:compile && electron .",
    "electron:build": "pnpm build && pnpm electron:prepare-standalone && pnpm electron:compile && npx electron-builder --mac --dir",
    "electron:publish": "pnpm build && pnpm electron:prepare-standalone && pnpm electron:compile && npx electron-builder --mac --publish always"
  },
  "bin": {
    "lumitask": "./cli/dist/index.js"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "electron"
    ]
  }
}